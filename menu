        starsContainer.addEventListener('mouseleave', () => {
            starsContainer.querySelectorAll('.star-btn').forEach(star => {
                star.classList.remove('hovered');
            });
        });

        starsContainer.addEventListener('click', (e) => {
            const btn = e.target.closest('.star-btn');
            if (!btn) return;
            selectedStars = parseInt(btn.dataset.value);
            
            starsContainer.querySelectorAll('.star-btn').forEach(star => {
                const val = parseInt(star.dataset.value);
                if (val <= selectedStars) {
                    star.classList.add('active');
                } else {
                    star.classList.remove('active');
                }
            });
        });

        function resetStars() {
            selectedStars = 0;
            starsContainer.querySelectorAll('.star-btn').forEach(star => {
                star.classList.remove('active', 'hovered');
            });
        }

        // Char count tracker
        reviewTextInput.addEventListener('input', () => {
            charCount.innerText = reviewTextInput.value.length;
        });

        // Save Review Submit Click
        saveReviewBtn.addEventListener('click', () => {
            if (!currentRecommendedMenu) return;
            
            if (selectedStars === 0) {
                showToast('별점을 선택해 주세요! ⭐', 'error');
                return;
            }

            const reviewObj = {
                date: new Date().toISOString(),
                menuName: currentRecommendedMenu.name,
                category: currentRecommendedMenu.category,
                rating: selectedStars,
                review: reviewTextInput.value.trim(),
                priceRange: currentRecommendedMenu.budget
            };

            saveReviewToGitHub(reviewObj);
        });

        // Search reviews list filter
        searchReviewsInput.addEventListener('input', () => {
            updateReviewsDashboard();
        });

        // Refresh reviews list
        refreshReviewsBtn.addEventListener('click', () => {
            loadReviewsFromGitHub();
            showToast('리뷰 목록을 갱신하였습니다.', 'success');
        });

        // ==============================================================================
        // 10. Initialization
        // ==============================================================================
        window.addEventListener('DOMContentLoaded', () => {
            loadSettings();
            
            // Check if GitHub credentials exist, if so load reviews automatically
            const token = localStorage.getItem('github_token');
            if (token) {
                loadReviewsFromGitHub();
            } else {
                showToast('우측 상단 톱니바퀴 설정을 클릭하여 GitHub 연동 설정을 채워보세요!', 'info');
            }
        });
    </script>
</body>
</html>
