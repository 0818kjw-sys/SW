            const path = ghPathInput.value.trim() || 'reviews.json';
            const mapsKey = gMapsKeyInput.value.trim();
            
            localStorage.setItem('github_token', token);
            localStorage.setItem('github_owner', owner);
            localStorage.setItem('github_repo', repo);
            localStorage.setItem('github_path', path);
            
            const prevMapsKey = localStorage.getItem('google_maps_key') || '';
            localStorage.setItem('google_maps_key', mapsKey);
            
            showToast('설정이 브라우저에 임시 저장되었습니다.', 'info');
            
            // Test connection
            const isConnected = await checkGitHubConnectionStatus();
            if (isConnected) {
                showToast('GitHub 연동이 성공적으로 활성화되었습니다! 🚀', 'success');
                loadReviewsFromGitHub();
            } else {
                showToast('GitHub 연동 인증에 실패했습니다. 토큰 및 저장소명을 확인하세요.', 'error');
            }

            // Load Google Maps if API key changed
            if (mapsKey && mapsKey !== prevMapsKey) {
                loadGoogleMapsJS(mapsKey);
            } else if (!mapsKey) {
                liveMenuDatabase = []; // clear google places database if key removed
            }

            settingsModal.classList.remove('open');
        });

        // ==============================================================================
        // 5. Google Maps JavaScript API (Places Library) 연동
        // ==============================================================================
        function loadGoogleMapsJS(apiKey) {
            if (window.google && window.google.maps && window.google.maps.places) {
                fetchGooglePlacesData();
                return;
            }

            // Remove any existing script tag
            const existingScript = document.getElementById('google-maps-js');
            if (existingScript) existingScript.remove();

            const script = document.createElement('script');
            script.id = 'google-maps-js';
            script.src = `https://maps.googleapis.com/maps/api/js?key=${apiKey}&libraries=places&language=ko&callback=initGooglePlacesService`;
            script.async = true;
            script.defer = true;
            script.onerror = () => {
                showToast('구글 맵스 API 로딩 실패. 키를 확인해 주세요.', 'error');
            };
            document.head.appendChild(script);
        }

        // Global Callback defined on window
        window.initGooglePlacesService = function() {
            showToast('Google Maps Places Library 연결 성공 🐯', 'success');
            fetchGooglePlacesData();
        };

        function fetchGooglePlacesData() {
            try {
                // Coordinate center: Korea University Main Gate/Anam Station area
                const kuCoords = new google.maps.LatLng(37.5894, 127.0325);
                const dummyDiv = document.createElement('div');
                const service = new google.maps.places.PlacesService(dummyDiv);

                const request = {
                    location: kuCoords,
                    radius: 500,
                    type: ['restaurant']
                };

                service.nearbySearch(request, (results, status) => {
                    if (status === google.maps.places.PlacesServiceStatus.OK) {
                        parseAndInjectGooglePlaces(results, kuCoords);
                    } else {
                        console.error('Google Places NearbySearch failed:', status);
                        showToast(`실시간 식당 조회 실패: ${status}`, 'error');
                    }
                });
            } catch (error) {
                console.error(error);
                showToast('구글 맵스 쿼리 중 오류 발생.', 'error');
            }
        }

        function parseAndInjectGooglePlaces(places, centerCoords) {
            liveMenuDatabase = places.map(place => {
                // Distance via Haversine
                const placeLoc = place.geometry.location;
                const distance = calculateDistance(
                    centerCoords.lat(), centerCoords.lng(),
                    placeLoc.lat(), placeLoc.lng()
                );

                const name = place.name;
                const lowerName = name.toLowerCase();
                let category = "한식"; // Default
                let emoji = "🍲";

                // Heuristic Classification based on Korean Keywords
                if (/(초밥|스시|카츠|돈까스|라멘|우동|소바|이자카야|돈가스|텐동|야끼|규동|사케|덮밥|미뇽)/.test(lowerName)) {
                    category = "일식";
                    emoji = "🍣";
                } else if (/(짬뽕|짜장|마라|마라탕|양꼬치|반점|객잔|차이나|꿔바로우|용초수|향록)/.test(lowerName)) {
                    category = "중식";
                    emoji = "🥟";
                } else if (/(떡볶이|김밥|분식|햇살|오뎅|순대|튀김|이공|엽떡)/.test(lowerName)) {
                    category = "분식";
                    emoji = "🍙";
                } else if (/(파스타|피자|버거|스테이크|양식|샌드위치|샐러드|이탈리안|버거|브레드|크레페|헤이피)/.test(lowerName)) {
                    category = "양식";
                    emoji = "🍝";
                } else {
                    // Check place types
                    if (place.types && place.types.includes('bakery')) {
                        category = "양식";
                        emoji = "🍞";
                    } else if (place.types && place.types.includes('cafe')) {
                        category = "양식";
                        emoji = "☕";
                    }
                }

                // Map distance to walk time
                const distanceText = distance <= 350 ? "도보 5분" : "도보 10분";

                // Map price level to budget tiers
                let budget = "1만원 이하";
                if (place.price_level !== undefined) {
                    if (place.price_level <= 1) budget = "5천원 이하";
                    else if (place.price_level === 2) budget = "1만원 이하";
                    else budget = "상관없음";
                } else {
                    // Common budget fallback heuristics
                    if (category === '분식' || lowerName.includes('국수') || lowerName.includes('김밥') || lowerName.includes('버거')) {
                        budget = "5천원 이하";
                    } else if (category === '일식' && (lowerName.includes('스시') || lowerName.includes('초밥') || lowerName.includes('참치'))) {
                        budget = "상관없음";
                    }
                }

                // Map party size
                let people = "둘다";
                if (/(삼겹살|갈비|회식|부대찌개|보쌈|족발|오봉집|전골|삼겹)/.test(lowerName)) {
                    people = "같이";
                } else if (/(김밥|라멘|우동|컵밥|덮밥|샌드위치|샐러드)/.test(lowerName)) {
                    people = "혼밥";
                }

                return {
                    name: name,
                    category: category,
                    budget: budget,
                    people: people,
                    distance: distanceText,
                    emoji: emoji,
                    isLive: true,
                    vicinity: place.vicinity || ''
                };
            });

            showToast(`구글 맵스 실시간 데이터 ${liveMenuDatabase.length}개 로딩 완료! 🗺️`, 'success');
        }

        // Distance formula
        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371e3; // Earth radius in meters
            const p1 = lat1 * Math.PI / 180;
            const p2 = lat2 * Math.PI / 180;
            const dp = (lat2 - lat1) * Math.PI / 180;
            const dl = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dp/2) * Math.sin(dp/2) +
                      Math.cos(p1) * Math.cos(p2) *
                      Math.sin(dl/2) * Math.sin(dl/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-c));
            return R * c;
        }

        // ==============================================================================
        // 6. GitHub API CRUD Operations
        // ==============================================================================
        async function makeGitHubRequest(options = {}) {
            const token = localStorage.getItem('github_token');
            const owner = localStorage.getItem('github_owner');
            const repo = localStorage.getItem('github_repo');
            const path = localStorage.getItem('github_path') || 'reviews.json';
            
            if (!token || !owner || !repo) {
                throw new Error('GitHub 설정을 마쳐주세요. 우측 상단의 톱니바퀴 버튼을 클릭하세요!');
            }
            
            const url = `https://api.github.com/repos/${owner}/${repo}/contents/${path}`;
            const headers = {
                'Authorization': `token ${token}`,
                'Accept': 'application/vnd.github.v3+json',
                'Content-Type': 'application/json'
            };
            
            const response = await fetch(url, { ...options, headers });
            if (!response.ok && response.status !== 404) {
                const errData = await response.json().catch(() => ({}));
                throw new Error(errData.message || `API HTTP ${response.status}`);
            }
            return response;
        }

        async function loadReviewsFromGitHub() {
            reviewsListContainer.innerHTML = '<div class="no-data"><i class="fa-solid fa-spinner loader"></i> 깃허브에서 리뷰 목록을 불러오는 중...</div>';
            
            try {
                const response = await makeGitHubRequest();
                if (response.status === 404) {
                    reviewsList = [];
                    updateReviewsDashboard();
                    return;
                }
                const data = await response.json();
                const content = atob(data.content.replace(/\s/g, ''));
                reviewsList = JSON.parse(decodeURIComponent(escape(content)));
                
                // Sort by date descending
                reviewsList.sort((a, b) => new Date(b.date) - new Date(a.date));
                updateReviewsDashboard();
            } catch (err) {
                console.error(err);
                reviewsListContainer.innerHTML = `<div class="no-data" style="color:var(--error);"><i class="fa-solid fa-triangle-exclamation"></i> 로딩 실패: ${err.message}</div>`;
            }
        }

        async function saveReviewToGitHub(newReview) {
            saveReviewBtn.disabled = true;
            saveReviewBtn.innerHTML = '<i class="fa-solid fa-spinner loader"></i> 저장 중...';
            
            try {
                let sha = null;
                let currentList = [];
                
                // 1. Get existing file content to find SHA & append
                const response = await makeGitHubRequest().catch(() => null);
                if (response && response.status === 200) {
                    const data = await response.json();
                    sha = data.sha;
                    const content = atob(data.content.replace(/\s/g, ''));
                    currentList = JSON.parse(decodeURIComponent(escape(content)));
                }
                
                // Add new item
                currentList.push(newReview);
                
                // 2. Commit it
                const updatedBase64 = btoa(unescape(encodeURIComponent(JSON.stringify(currentList, null, 2))));
                const body = {
                    message: `add review for ${newReview.menuName} via tiger-recommender`,
                    content: updatedBase64
                };
                if (sha) {
                    body.sha = sha;
                }
                
                const putResponse = await makeGitHubRequest({
                    method: 'PUT',
                    body: JSON.stringify(body)
                });
                
                if (putResponse.ok) {
                    reviewsList = currentList;
                    reviewsList.sort((a, b) => new Date(b.date) - new Date(a.date));
                    updateReviewsDashboard();
                    
                    // Reset review inputs
                    reviewSection.style.display = 'none';
                    reviewTextInput.value = '';
                    charCount.innerText = '0';
                    resetStars();
                    
                    showToast('리뷰가 깃허브에 영구 저장되었습니다! 🐯', 'success');
                    
                    // Smooth scroll to top of logs
                    document.querySelector('.logs-section').scrollIntoView({ behavior: 'smooth' });
                } else {
                    throw new Error('전송 중 상태 응답 에러');
                }
            } catch (err) {
                console.error(err);
                showToast(`저장에 실패했습니다: ${err.message}`, 'error');
            } finally {
                saveReviewBtn.disabled = false;
                saveReviewBtn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> 후기 저장 💾';
            }
        }

        // ==============================================================================
        // 7. Core Recommender Logics
        // ==============================================================================
        function runRandomMenuRecommendation() {
            // Get selected values
            const activePeopleBtn = peopleFilter.querySelector('.segment-btn.active');
            const activeBudgetBtn = budgetFilter.querySelector('.segment-btn.active');
            const activeDistanceBtn = distanceFilter.querySelector('.segment-btn.active');
            
            // Check validation
            if (!activePeopleBtn || !activeBudgetBtn) {
                showToast('인원 구성과 예산 범위를 선택해 주세요! 🐯', 'error');
                return;
            }

            const peopleVal = activePeopleBtn.dataset.value;
            const budgetVal = activeBudgetBtn.dataset.value;
            const distanceVal = activeDistanceBtn ? activeDistanceBtn.dataset.value : '상관없음';

            // Get excluded categories (checked ones)
            const excludedCategories = Array.from(excludeFilter.querySelectorAll('.chip-checkbox:checked'))
                .map(cb => cb.value);

            // Merge local and live databases
            const fullDatabase = [...localMenuDatabase, ...liveMenuDatabase];

            // Perform filtering
            let filteredList = fullDatabase.filter(menu => {
                // 1. People filter
                if (menu.people !== '둘다' && menu.people !== peopleVal) {
                    return false;
                }

                // 2. Budget filter
                if (budgetVal !== '상관없음') {
                    if (budgetVal === '5천원 이하' && menu.budget !== '5천원 이하') {
                        return false;
                    }
                    if (budgetVal === '1만원 이하' && menu.budget === '상관없음') {
                        return false;
                    }
                }

                // 3. Distance filter
                if (distanceVal !== '상관없음') {
                    if (distanceVal === '도보 5분' && menu.distance !== '도보 5분') {
                        return false;
                    }
                }

                // 4. Excluded categories
                if (excludedCategories.includes(menu.category)) {
                    return false;
                }

                // 5. Exclude session disliked menus
                if (sessionExcludedList.includes(menu.name)) {
                    return false;
                }

                return true;
            });

            // Handle empty list cases
            if (filteredList.length === 0) {
                // If it's because everything is in session excluded list
                const hasExcludedAll = fullDatabase.filter(menu => {
                    if (menu.people !== '둘다' && menu.people !== peopleVal) return false;
                    if (budgetVal !== '상관없음') {
                        if (budgetVal === '5천원 이하' && menu.budget !== '5천원 이하') return false;
                        if (budgetVal === '1만원 이하' && menu.budget === '상관없음') return false;
                    }
                    if (distanceVal !== '상관없음' && distanceVal === '도보 5분' && menu.distance !== '도보 5분') return false;
                    if (excludedCategories.includes(menu.category)) return false;
                    return true;
                }).length > 0;

                if (hasExcludedAll && sessionExcludedList.length > 0) {
                    recommendationArea.innerHTML = `
                        <div class="menu-card" style="padding: 20px;">
                            <div class="menu-emoji">🔄</div>
                            <div class="menu-name" style="font-size:1.5rem; color:var(--secondary);">모든 메뉴를 다 봤어요!</div>
                            <p style="color:var(--text-muted); font-size:0.9rem; margin-bottom:15px;">조건을 변경하거나 제외 목록을 초기화할까요?</p>
                            <button type="button" class="btn" id="resetSessionExcludesBtn" style="margin: 0 auto; padding:8px 16px; font-size:0.85rem;">제외 목록 초기화 🔄</button>
                        </div>
                    `;
                    recommendationArea.classList.add('has-content');
                    postRecommendActions.style.display = 'none';
                    reviewSection.style.display = 'none';
                    
                    document.getElementById('resetSessionExcludesBtn').addEventListener('click', () => {
                        sessionExcludedList = [];
                        showToast('제외된 이전 메뉴들이 초기화되었습니다!', 'success');
                        runRandomMenuRecommendation();
                    });
                } else {
                    recommendationArea.innerHTML = `
                        <div class="recommendation-placeholder">
                            <i class="fa-solid fa-triangle-exclamation" style="color:var(--warning);"></i>
                            <span style="font-weight:700; color:var(--warning);">조건에 맞는 메뉴가 없어요!</span>
                            <span style="font-size:0.85rem; color:var(--text-muted);">제외 카테고리를 해제하거나 예산/거리 필터를 넓혀보세요.</span>
                        </div>
                    `;
                    recommendationArea.classList.remove('has-content');
                    postRecommendActions.style.display = 'none';
                    reviewSection.style.display = 'none';
                }
                return;
            }

            // Pick 1 random item
            const randomIndex = Math.floor(Math.random() * filteredList.length);
            const pickedMenu = filteredList[randomIndex];
            currentRecommendedMenu = pickedMenu;

            // Render picked menu
            let liveTagHtml = pickedMenu.isLive ? `<span class="tag tag-live"><i class="fa-solid fa-map-location-dot"></i> Google Maps</span>` : '';
            let addressHtml = pickedMenu.vicinity ? `<div class="menu-address"><i class="fa-solid fa-location-dot"></i> ${pickedMenu.vicinity}</div>` : '';

            recommendationArea.innerHTML = `
                <div class="menu-card">
                    <span class="menu-emoji">${pickedMenu.emoji}</span>
                    <h2 class="menu-name">${pickedMenu.name}</h2>
                    <div class="menu-tags">
                        <span class="tag tag-category">${pickedMenu.category}</span>
                        <span class="tag tag-budget">${pickedMenu.budget}</span>
                        <span class="tag tag-distance">${pickedMenu.distance}</span>
                        ${liveTagHtml}
                    </div>
                    ${addressHtml}
                </div>
            `;
            recommendationArea.classList.add('has-content');

            // Show action buttons
            postRecommendActions.style.display = 'grid';
            
            // Hide review section when recommendation changes
            reviewSection.style.display = 'none';
        }

        // ==============================================================================
        // 8. Stats & Reviews Dashboard Rendering
        // ==============================================================================
        function updateReviewsDashboard() {
            const filteredReviews = filterReviewsList();
            
            // Render Reviews Items
            if (filteredReviews.length === 0) {
                reviewsListContainer.innerHTML = '<div class="no-data">조건에 맞거나 등록된 리뷰가 없습니다.</div>';
            } else {
                reviewsListContainer.innerHTML = filteredReviews.map(review => {
                    let starsHtml = '';
                    for (let i = 1; i <= 5; i++) {
                        if (i <= review.rating) {
                            starsHtml += '<i class="fa-solid fa-star"></i>';
                        } else {
                            starsHtml += '<i class="fa-regular fa-star"></i>';
                        }
                    }

                    const dateFormatted = new Date(review.date).toLocaleDateString('ko-KR', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });

                    return `
                        <div class="review-item">
                            <div class="review-item-header">
                                <div class="review-item-title">${review.menuName}</div>
                                <div class="review-item-rating">${starsHtml}</div>
                            </div>
                            <div class="review-item-content">${review.review || '후기가 없습니다.'}</div>
                            <div class="review-item-meta">
                                <span><i class="fa-solid fa-tags"></i> ${review.category || '기타'} | ${review.priceRange || '정보 없음'}</span>
                                <span>${dateFormatted}</span>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            // Calculate Dashboard Statistics
            if (reviewsList.length === 0) {
                statTotal.innerText = '0';
                statAvg.innerText = '0.0';
                statTopMenu.innerText = '없음';
                return;
            }

            // Total
            statTotal.innerText = reviewsList.length;

            // Average Star Rating
            const totalRatingSum = reviewsList.reduce((sum, r) => sum + r.rating, 0);
            const averageRating = (totalRatingSum / reviewsList.length).toFixed(1);
            statAvg.innerText = averageRating;

            // Highest Rated Menu (Average rating per unique menu with at least 1 review)
            const menuRatings = {};
            reviewsList.forEach(r => {
                if (!menuRatings[r.menuName]) {
                    menuRatings[r.menuName] = { sum: 0, count: 0 };
                }
                menuRatings[r.menuName].sum += r.rating;
                menuRatings[r.menuName].count += 1;
            });

            let topMenuName = '없음';
            let highestMenuAvg = 0;
            
            for (const menuName in menuRatings) {
                const avg = menuRatings[menuName].sum / menuRatings[menuName].count;
                if (avg > highestMenuAvg) {
                    highestMenuAvg = avg;
                    topMenuName = `${menuName} (${avg.toFixed(1)}점)`;
                }
            }
            statTopMenu.innerText = topMenuName;
            statTopMenu.title = topMenuName; // Tooltip for full text if truncated
        }

        function filterReviewsList() {
            const query = searchReviewsInput.value.toLowerCase().trim();
            if (!query) return reviewsList;

            return reviewsList.filter(review => {
                return (
                    review.menuName.toLowerCase().includes(query) ||
                    (review.review && review.review.toLowerCase().includes(query)) ||
                    (review.category && review.category.toLowerCase().includes(query))
                );
            });
        }

